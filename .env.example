# ====================================================================
# STRIPE CONFIGURATION - V8 PRODUCTION PRICE IDs
# ====================================================================

# Stripe API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ====================================================================
# One-time products
# ====================================================================
STRIPE_PDPA_QUICK_SCAN=            # SGD 299 (One-time)
STRIPE_VENDOR_PROOF=               # SGD 149 (One-time)
STRIPE_RFP_COMPLETE=               # SGD 599 (One-time)
STRIPE_COMPLIANCE_NOTARIZATION_1=  # SGD 69 (One-time)
STRIPE_NOTARIZATION_ADDON_1=       # SGD 29 (One-time — extra notarization top-up)
STRIPE_COMPLIANCE_NOTARIZATION_10= # SGD 390/mo (Subscription — Small Batch, 10 notarizations/mo)
STRIPE_COMPLIANCE_NOTARIZATION_50= # SGD 1,750/mo (Subscription — Enterprise Batch, 50 notarizations/mo)

# ====================================================================
# Bundles (one-time)
# ====================================================================
STRIPE_VENDOR_TRUST_PACK=          # SGD 249 (One-time)
STRIPE_RFP_ACCELERATOR=            # SGD 449 (One-time — includes RFP Express)
STRIPE_ENTERPRISE_BID_KIT=         # SGD 899 (One-time)
STRIPE_COMPLIANCE_EVIDENCE_PACK=   # SGD 799 (One-time)

# ====================================================================
# Subscriptions
# ====================================================================
STRIPE_VENDOR_ACTIVE_MONTHLY=             # SGD 39/month
STRIPE_VENDOR_ACTIVE_ANNUAL=              # SGD 390/year (≈ 2 months free)
STRIPE_VENDOR_PRO_MONTHLY=                # SGD 99/month
STRIPE_VENDOR_PRO_ANNUAL=                 # SGD 1,099/year (≈ 2 months free)
STRIPE_PDPA_MONITOR_MONTHLY=              # SGD 299/month
STRIPE_PDPA_MONITOR_ANNUAL=               # SGD 2,990/year (≈ 2 months free)
STRIPE_COMPLIANCE_EVIDENCE_MONTHLY=       # SGD 499/month
STRIPE_TENDER_INTELLIGENCE_MONTHLY=       # SGD 149/month
STRIPE_TENDER_INTELLIGENCE_ANNUAL=        # SGD 1,499/year (≈ 2 months free)
STRIPE_STANDARD_SUITE_MONTHLY=            # SGD 1,800/month
STRIPE_PRO_SUITE_MONTHLY=                 # SGD 4,500/month

# ── Buyer ladder (procurement-only) ─────────────────────────────────
STRIPE_BUYER_STARTER_MONTHLY=             # SGD 149/month
STRIPE_BUYER_STARTER_ANNUAL=              # SGD 1,520/year (save SGD 268)
STRIPE_BUYER_PRO_MONTHLY=                 # SGD 399/month
STRIPE_BUYER_PRO_ANNUAL=                  # SGD 4,070/year (save SGD 718)
STRIPE_BUYER_ENTERPRISE_MONTHLY=          # SGD 799/month
STRIPE_BUYER_ENTERPRISE_ANNUAL=           # SGD 8,150/year (save SGD 1,438)

# ── Legacy / grandfathered — DO NOT set for new deployments ─────────
# These SKUs are no longer sold on /pricing but are kept in code so existing
# subscriptions can renew and resolve to the correct plan. Leave blank.
# STRIPE_ENTERPRISE_MONTHLY=              # legacy
# STRIPE_ENTERPRISE_PRO_MONTHLY=          # legacy
# STRIPE_EVALUATE_SUPPLIERS_MONTHLY=      # legacy (replaced by buyer_pro_monthly)
# STRIPE_VERIFY_SUPPLIER_EVIDENCE_MONTHLY= # legacy (replaced by buyer_enterprise_monthly)

